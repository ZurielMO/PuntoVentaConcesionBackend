# Example only. Do not put real credentials in this file.
# Copia este archivo a `.env.local` y coloca valores reales ahí.
# En producción usa Firebase Secret Manager.

# ---------------------------------------------------------------------------
# Runtime / server
# ---------------------------------------------------------------------------
IS_LOCAL=true
NODE_ENV=development
PORT=3000
APP_PORT=3000

# ===========================================================================
# PROYECTO POS PRINCIPAL: puntoventacl - Firestore base nombrada "concesiones"
# ===========================================================================
PROJECT_ID=puntoventacl
FIREBASE_PROJECT_ID=puntoventacl
GCP_PROJECT_ID=puntoventacl
STORAGE_BUCKET=puntoventacl.firebasestorage.app
FIRESTORE_DATABASE_ID=concesiones

# Credenciales locales (una de estas opciones):
#  a) Coloca serviceAccountKey.json o serviceAccountPos.json en la raíz del repo.
#  b) Define la ruta absoluta:
GOOGLE_APPLICATION_CREDENTIALS=
#  c) Pega el JSON inline:
SERVICE_ACCOUNT_KEY=

# Login DEV por contraseña (POST /api/auth/login/password) -> Identity Toolkit.
# Usa el Web API Key del proyecto puntoventacl.
FIREBASE_API_KEY=
CLIENT_FIREBASE_API_KEY=
AUTH_API_KEY=

# ===========================================================================
# APP SECUNDARIA (solo jornadas): acreditaciones-b904f - Realtime Database
# ===========================================================================
REALTIME_DATABASE_URL_APP_OFICIAL2=https://acreditaciones-b904f-default-rtdb.firebaseio.com
# Credenciales (una de estas opciones):
#  a) acreditaciones.serviceAccountKey.json en la raíz del repo.
#  b) ruta explícita:
SERVICE_ACCOUNT_APP_OFICIAL2_PATH=
#  c) JSON inline:
SERVICE_ACCOUNT_APP_OFICIAL2=

# ===========================================================================
# Integración de puntos de concesión -> backend app oficial (e-comerce-leon)
# ===========================================================================
CONCESSION_POINTS_ASSIGN_URL=https://us-central1-e-comerce-leon.cloudfunctions.net/api/api/usuarios
CONCESSION_POINTS_SOURCE_SYSTEM=backendcl
CONCESSION_POINTS_SOURCE_SECRET=
ORIGIN_ID_SECRET=

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
STORE_PUBLIC_BASE_URL=
